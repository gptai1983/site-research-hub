# AI Providers (required)
GROQ_API_KEY=your_groq_key_here
OPENCODE_API_KEY=your_opencode_key_here
GEMINI_API_KEY=your_gemini_key_here

# JWT Secret (required for production — generate a random 64-char hex string)
JWT_SECRET=

# Optional: Custom encryption key (auto-generated if empty)
ENCRYPTION_KEY=

# Optional: Database path (default: data.db)
DB_PATH=data.db

# Optional: Backup directory (default: ./backups)
BACKUP_DIR=./backups

# Optional: Logging level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Optional: Node environment
NODE_ENV=development

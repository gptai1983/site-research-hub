{
  "name": "hermes-site-research",
  "version": "1.0.0",
  "description": "AI-powered site research hub with browser automation",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npx tsx scripts/test-api.ts",
    "playwright-install": "playwright install chromium",
    "docker:build": "docker build -t hermes-backend .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "setup": "npm install && npx playwright install chromium && echo 'Setup complete'"
  },
  "dependencies": {
    "@hono/node-server": "^0.5.0",
    "@hono/trpc-server": "^0.4.0",
    "@trpc/server": "^11.8.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.0",
    "hono": "^4.8.0",
    "jsonwebtoken": "^9.0.3",
    "playwright": "^1.48.0",
    "sql.js": "^1.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/node-fetch": "^2.6.11",
    "@types/sql.js": "^1.4.9",
    "node-fetch": "^3.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
